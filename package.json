{
  "name": "frontend-worship-decisions",
  "version": "0.17.1",
  "private": true,
  "description": "Frontend of the Worship Decisions application",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lblod/frontend-worship-decisions.git"
  },
  "license": "MIT",
  "author": "info@redpencil.io",
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "scripts": {
    "build": "vite build",
    "format": "prettier . --cache --write",
    "lint": "concurrently \"npm:lint:*(!fix)\" --names \"lint:\" --prefixColors auto",
    "lint:css": "stylelint \"**/*.css\" --allow-empty-input",
    "lint:css:fix": "concurrently \"npm:lint:css -- --fix\"",
    "lint:fix": "concurrently \"npm:lint:*:fix\" --names \"fix:\" --prefixColors auto && npm run format",
    "lint:format": "prettier . --cache --check",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:deps": "ember dependency-lint",
    "release": "release-it",
    "start": "vite",
    "test": "concurrently \"npm:lint\" \"npm:test:*\" --names \"lint,test:\" --prefixColors auto",
    "test:ember": "vite build --mode development && ember test --path dist"
  },
  "devDependencies": {
    "@appuniversum/ember-appuniversum": "^3.18.0",
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@ember/optional-features": "^2.3.0",
    "@ember/render-modifiers": "^4.0.0",
    "@ember/string": "^4.0.1",
    "@ember/test-helpers": "^5.4.1",
    "@embroider/compat": "^4.1.17",
    "@embroider/config-meta-loader": "^1.0.0",
    "@embroider/core": "^4.4.7",
    "@embroider/legacy-inspector-support": "^0.1.3",
    "@embroider/macros": "^1.20.2",
    "@embroider/vite": "^1.7.2",
    "@eslint/js": "^9.39.4",
    "@glimmer/component": "^2.1.1",
    "@glimmer/tracking": "^1.1.2",
    "@lblod/ember-acmidm-login": "^2.3.0",
    "@lblod/ember-mock-login": "^0.14.0",
    "@lblod/ember-submission-form-fields": "^3.6.0",
    "@lblod/submission-form-helpers": "^3.1.0",
    "@rollup/plugin-babel": "^6.1.0",
    "@warp-drive/core": "~5.8.1",
    "@warp-drive/json-api": "~5.8.1",
    "@warp-drive/legacy": "~5.8.1",
    "@warp-drive/utilities": "~5.8.1",
    "babel-plugin-ember-template-compilation": "^3.1.0",
    "client-zip": "^2.5.0",
    "concurrently": "^9.2.1",
    "decorator-transforms": "^2.3.1",
    "ember-auto-import": "^2.13.1",
    "ember-basic-dropdown": "^8.11.0",
    "ember-cli": "~6.12.0",
    "ember-cli-babel": "^8.3.1",
    "ember-cli-dependency-lint": "^2.0.1",
    "ember-cli-deprecation-workflow": "^3.4.0",
    "ember-cli-htmlbars": "^7.0.1",
    "ember-cli-sass": "^11.0.1",
    "ember-concurrency": "^5.2.0",
    "ember-data": "~5.8.2",
    "ember-load-initializers": "^3.0.1",
    "ember-modifier": "^4.3.0",
    "ember-moment": "^11.1.0",
    "ember-mu-transform-helpers": "^2.0.0",
    "ember-page-title": "^9.0.3",
    "ember-plausible": "^0.5.0",
    "ember-power-select": "^8.12.0",
    "ember-qunit": "^9.0.4",
    "ember-resolver": "^13.2.0",
    "ember-simple-auth": "^8.3.0",
    "ember-source": "~6.12.0",
    "ember-template-lint": "^6.1.0",
    "ember-truth-helpers": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-ember": "^12.7.5",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-qunit": "^8.2.6",
    "eslint-plugin-warp-drive": "^5.8.1",
    "globals": "^15.15.0",
    "lodash.camelcase": "4.3.0",
    "moment": "^2.29.4",
    "prettier": "^3.8.1",
    "prettier-plugin-ember-template-tag": "^2.1.4",
    "qunit": "^2.25.0",
    "qunit-dom": "^3.5.0",
    "rdflib": "^2.3.6",
    "release-it": "^15.4.1",
    "sass": "^1.48.0",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^36.0.1",
    "uuid": "^11.0.3",
    "vite": "^7.3.1"
  },
  "engines": {
    "node": ">= 20.19"
  },
  "ember": {
    "edition": "octane"
  },
  "exports": {
    "./tests/*": "./tests/*",
    "./*": "./app/*"
  }
}